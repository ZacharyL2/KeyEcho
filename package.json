{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "bench:audio": "cargo test --release --manifest-path src-tauri/Cargo.toml reference_timing -- --ignored --nocapture",
    "install:model-m-test-pack": "tsx scripts/install-model-m-test-pack.ts",
    "install:derived-press-release-packs": "tsx scripts/install-derived-press-release-packs.ts",
    "test": "pnpm run test:rust && pnpm run web:test && pnpm run web:build",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "updater": "tsx scripts/updater.ts",
    "release-notes": "tsx scripts/release-notes.ts",
    "postinstall": "simple-git-hooks",
    "preinstall": "npx only-allow pnpm",
    "web:dev": "vite",
    "web:test": "vitest run --environment node",
    "web:build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "solid-js": "^1.9.13",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@actions/github": "^9.1.1",
    "@antfu/eslint-config": "^9.1.0",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.1",
    "@unocss/reset": "^66.7.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.1.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
