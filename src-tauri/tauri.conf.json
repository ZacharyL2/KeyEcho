{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeyEcho",
  "version": "1.0.0",
  "identifier": "xyz.waveapps.keyecho",
  "mainBinaryName": "KeyEcho",
  "build": {
    "beforeDevCommand": "pnpm run web:dev",
    "beforeBuildCommand": "pnpm run web:build",
    "devUrl": "http://localhost:3426",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' tauri: asset:; connect-src 'self' ipc: http://ipc.localhost http://localhost:3426 ws://localhost:3426 https://api.github.com https://raw.githubusercontent.com; img-src 'self' asset: data:; script-src 'self'; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "GNU Affero General Public License v3.0",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxRjI2Njg0MjBENTUwRDQKUldUVVVOVWdoR2J5d1drWEJhWGl6UU9GNmlWUHJqUjJJRVpBbVZZeHh3YlF2MlRkNERHUjFEOUYK",
      "endpoints": [
        "https://github.com/ZacharyL2/KeyEcho/releases/download/updater/update.json"
      ]
    }
  }
}
